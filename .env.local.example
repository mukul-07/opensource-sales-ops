# sales-ops secrets — API keys for lead enrichment
#
# SECURITY RULES (do not skip):
#   1. Copy this file to .env.local (already gitignored).
#   2. NEVER rename to .envrc — that file is tracked in git.
#   3. NEVER paste keys into chat / Slack / tickets / screenshots.
#   4. If a key ever leaves your machine (chat, screen share, public laptop),
#      rotate it immediately at the source's dashboard.
#
# How it loads:
#   .envrc runs `dotenv_if_exists .env.local`, so direnv picks these up
#   automatically. If you don't use direnv, `source .env.local` works too
#   (dotenv syntax is plain shell).
#
# Leave any line blank if you don't use that source yet.

# Apollo.io — https://app.apollo.io/ Settings → API
export APOLLO_API_KEY=""

# Hunter.io — https://hunter.io/api-keys
export HUNTER_API_KEY=""

# Snov.io — OAuth2, needs both ID and Secret
# https://app.snov.io/account#api_settings
export SNOV_CLIENT_ID=""
export SNOV_CLIENT_SECRET=""

# Prospeo.io — https://app.prospeo.io/account/api
export PROSPEO_API_KEY=""

# Skrapp.io — https://www.skrapp.io/en/dashboard/api
export SKRAPP_API_KEY=""
